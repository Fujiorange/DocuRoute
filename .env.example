# Copy this file to .env.local and fill in your values.
# Do NOT commit .env.local to Git — it contains secrets.

# ============================================
# DATABASE
# ============================================
# PostgreSQL connection string
# Local example:  postgresql://postgres:yourpassword@localhost:5432/docuroute
# Neon example:   postgresql://user:password@ep-xxx.us-east-1.aws.neon.tech/docuroute?sslmode=require
DATABASE_URL="postgresql://USER:PASSWORD@HOST:PORT/DATABASE"

# ============================================
# AUTHENTICATION
# ============================================
# Secret key used to sign JWT tokens.
# Must be at least 32 random characters. Keep this secret!
# Generate one with (macOS/Linux/PowerShell/Git Bash):
#   node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
JWT_SECRET="change-me-to-a-long-random-secret-at-least-32-chars"

# ============================================
# APPLICATION
# ============================================
# The URL where the app is running. Use http://localhost:3000 for local development.
NEXT_PUBLIC_APP_URL="http://localhost:3000"

# Node environment (development, production)
NODE_ENV="development"

# ============================================
# AWS S3 STORAGE
# ============================================
# AWS credentials for S3 storage
AWS_ACCESS_KEY_ID="your-aws-access-key-id"
AWS_SECRET_ACCESS_KEY="your-aws-secret-access-key"
AWS_REGION="ap-southeast-1"  # Singapore region
AWS_S3_BUCKET="docuroute-documents"

# Optional: Alternative to AWS S3 - Backblaze B2
# B2_KEY_ID="your-b2-key-id"
# B2_APPLICATION_KEY="your-b2-application-key"
# B2_BUCKET_NAME="docuroute-documents"
# B2_ENDPOINT="https://s3.ap-southeast-1.backblazeb2.com"

# Encryption key for at-rest encryption (32 bytes / 64 hex chars)
# Generate with: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
ENCRYPTION_KEY="change-me-to-a-64-character-hex-string-for-encryption"

# ============================================
# EMAIL SERVICE
# ============================================
# Resend API key (https://resend.com)
# Alternative: SendGrid API key (SENDGRID_API_KEY)
RESEND_API_KEY="re_your-resend-api-key"
EMAIL_FROM="noreply@docuroute.com"
EMAIL_FROM_NAME="DocuRoute"

# ============================================
# MONITORING & ERROR TRACKING
# ============================================
# Sentry DSN for error tracking (https://sentry.io)
SENTRY_DSN="https://your-sentry-dsn@sentry.io/project-id"
SENTRY_ORG="your-org"
SENTRY_PROJECT="docuroute"
SENTRY_AUTH_TOKEN="your-sentry-auth-token"

# ============================================
# RATE LIMITING
# ============================================
# Rate limit: max requests per window (default: 100 requests per 15 minutes)
RATE_LIMIT_MAX="100"
RATE_LIMIT_WINDOW_MS="900000"  # 15 minutes in milliseconds

# ============================================
# FEATURE FLAGS
# ============================================
# Enable/disable 2FA (default: true in production)
ENABLE_2FA="true"

# Enable/disable audit logging (default: true)
ENABLE_AUDIT_LOG="true"

# Maximum file upload size in bytes (default: 200 MB)
MAX_FILE_SIZE="209715200"

# ============================================
# PDPA/GDPR COMPLIANCE
# ============================================
# Data retention period in days (default: 2555 days / 7 years for Singapore construction)
DATA_RETENTION_DAYS="2555"

# Enable automatic data export requests
ENABLE_DATA_EXPORT="true"

# Enable account deletion requests
ENABLE_ACCOUNT_DELETION="true"
