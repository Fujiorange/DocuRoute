# Copy this file to .env.local and fill in your values.
# Do NOT commit .env.local to Git — it contains secrets.

# PostgreSQL connection string
# Local example:  postgresql://postgres:yourpassword@localhost:5432/docuroute
# Neon example:   postgresql://user:password@ep-xxx.us-east-1.aws.neon.tech/docuroute?sslmode=require
DATABASE_URL="postgresql://USER:PASSWORD@HOST:PORT/DATABASE"

# Secret key used to sign JWT tokens.
# Must be at least 32 random characters. Keep this secret!
# Generate one with (macOS/Linux/PowerShell/Git Bash):
#   node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
JWT_SECRET="change-me-to-a-long-random-secret-at-least-32-chars"

# The URL where the app is running. Use http://localhost:3000 for local development.
NEXT_PUBLIC_APP_URL="http://localhost:3000"
